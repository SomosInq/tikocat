{%- comment -%}
  Email popup section.

  - Shows once automatically on a visitor's first session (localStorage-based),
    with an optional delay and an optional "show again after N days" setting.
  - Can also be opened manually at any time from anywhere in the theme by
    linking to the configured anchor id, e.g. <a href="#open-subscribe-popup">.
  - Right-hand content area accepts any theme block or app block, so you can
    mix heading / text / email-form / app blocks freely in the theme editor.
{%- endcomment -%}

{%- assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0 -%}
{%- assign overlay_rgba = section.settings.overlay_color | color_modify: 'alpha', overlay_alpha -%}

<subscribe-popup
  id="SubscribePopup-{{ section.id }}"
  class="subscribe-popup"
  data-trigger-id="{{ section.settings.trigger_id | escape }}"
  data-auto-open="{{ section.settings.auto_open }}"
  data-auto-open-delay="{{ section.settings.auto_open_delay }}"
  data-reopen-after-days="{{ section.settings.reopen_after_days }}"
>
  <dialog
    class="subscribe-popup__dialog"
    aria-labelledby="SubscribePopupHeading-{{ section.id }}"
    style="--overlay-color: {{ overlay_rgba }};"
  >
  
    <div
      class="subscribe-popup__box color-{{ section.settings.color_scheme }}"
      style="--popup-width: {{ section.settings.popup_width }}px; --popup-radius: {{ section.settings.corner_radius }}px;"
    >
    <div class="section-background color-{{ section.settings.color_scheme }}"></div>
      <button type="button" class="subscribe-popup__close" data-popup-close aria-label="Close">
        <svg viewBox="0 0 18 18" width="18" height="18" fill="none" aria-hidden="true" focusable="false">
          <path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>

      <div class="subscribe-popup__inner{% if section.settings.image_position == 'right' %} subscribe-popup__inner--reverse{% endif %}">
        {%- if section.settings.image -%}
          <div class="subscribe-popup__media">
            {{
              section.settings.image
              | image_url: width: 1500
              | image_tag:
                loading: 'lazy',
                widths: '400,600,800,1000,1500',
                sizes: '(min-width: 750px) 50vw, 100vw',
                class: 'subscribe-popup__image',
                alt: section.settings.image.alt
            }}
          </div>
        {%- endif -%}

        <div class="subscribe-popup__content" id="SubscribePopupHeading-{{ section.id }}">
          {% content_for 'blocks' %}
        </div>
      </div>
    </div>
  </dialog>
</subscribe-popup>

{% stylesheet %}
  .subscribe-popup__dialog {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100vw;
    max-height: 100vh;
    margin: 0;
    padding: 1.5rem;
    border: none;
    background: var(--overlay-color, rgba(0, 0, 0, 0.6));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .subscribe-popup__dialog:not([open]) {
    display: none;
  }

  .subscribe-popup__dialog::backdrop {
    background: transparent;
  }

  .subscribe-popup__box {
    position: relative;
    width: 100%;
    max-width: var(--popup-width, 800px);
    max-height: 100%;
    overflow: auto;
    border-radius: var(--popup-radius, 12px);
    background: rgb(var(--color-background, 255 255 255));
    color: rgb(var(--color-foreground, 0 0 0));
  }

  .subscribe-popup__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgb(var(--color-background, 255 255 255));
    color: inherit;
    cursor: pointer;
  }

  .subscribe-popup__close:hover {
    opacity: 0.7;
  }

  .subscribe-popup__inner {
    display: grid;
    grid-template-columns: 1fr;
  }

  .subscribe-popup__media {
    order: 1;
  }

  .subscribe-popup__content {
    order: 2;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
  }

  .subscribe-popup__inner--reverse .subscribe-popup__media {
    order: 2;
  }

  .subscribe-popup__inner--reverse .subscribe-popup__content {
    order: 1;
  }

  .subscribe-popup__image {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 260px;
    object-fit: cover;
  }

  @media (min-width: 750px) {
    .subscribe-popup__inner {
      grid-template-columns: 1fr 1fr;
      min-height: 420px;
    }

    .subscribe-popup__media {
      height: 100%;
    }

    .subscribe-popup__image {
      max-height: none;
    }

    .subscribe-popup__content {
      justify-content: center;
      padding: 3rem;
    }
  }

  html.subscribe-popup-open {
    overflow: hidden;
  }
{% endstylesheet %}

{% javascript %}
  class SubscribePopup extends HTMLElement {
    constructor() {
      super();
      this.dialog = this.querySelector('dialog');
      this.triggerId = this.dataset.triggerId;
      this.storageKey = 'subscribe-popup-seen:' + this.id;
      this.reopenAfterDays = parseInt(this.dataset.reopenAfterDays, 10) || 0;
    }

    connectedCallback() {
      this.querySelectorAll('[data-popup-close]').forEach((button) => {
        button.addEventListener('click', () => this.close());
      });

      // Clicking the backdrop area (outside the box) closes the popup.
      this.dialog.addEventListener('click', (event) => {
        if (event.target === this.dialog) this.close();
      });

      this.dialog.addEventListener('close', () => {
        document.documentElement.classList.remove('subscribe-popup-open');
      });

      // Manual trigger: any link/element referencing this popup's trigger id
      // anywhere in the theme opens it, e.g. <a href="#open-subscribe-popup">.
      if (this.triggerId) {
        const selector =
          'a[href="#' + this.triggerId + '"], [data-popup-trigger="' + this.triggerId + '"]';
        document.addEventListener('click', (event) => {
          const trigger = event.target.closest(selector);
          if (!trigger) return;
          event.preventDefault();
          this.open();
        });
      }

      if (this.dataset.autoOpen === 'true' && this.shouldAutoOpen()) {
        const delay = (parseInt(this.dataset.autoOpenDelay, 10) || 0) * 1000;
        setTimeout(() => this.open(), delay);
      }
    }

    shouldAutoOpen() {
      const seenAt = localStorage.getItem(this.storageKey);
      if (!seenAt) return true;
      if (this.reopenAfterDays <= 0) return false;
      const daysElapsed = (Date.now() - parseInt(seenAt, 10)) / 86400000;
      return daysElapsed >= this.reopenAfterDays;
    }

    open() {
      if (this.dialog.open) return;
      this.dialog.showModal();
      document.documentElement.classList.add('subscribe-popup-open');
      localStorage.setItem(this.storageKey, Date.now().toString());
    }

    close() {
      this.dialog.close();
    }
  }

  customElements.define('subscribe-popup', SubscribePopup);
{% endjavascript %}

{% schema %}
{
  "name": "Email popup",
  "settings": [
    {
      "type": "header",
      "content": "Trigger"
    },
    {
      "type": "checkbox",
      "id": "auto_open",
      "label": "Automatically open on first visit",
      "default": true
    },
    {
      "type": "range",
      "id": "auto_open_delay",
      "label": "Delay before opening",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "s",
      "default": 3
    },
    {
      "type": "range",
      "id": "reopen_after_days",
      "label": "Show again after",
      "info": "Set to 0 to show only once per visitor, ever.",
      "min": 0,
      "max": 90,
      "step": 1,
      "unit": "d",
      "default": 0
    },
    {
      "type": "text",
      "id": "trigger_id",
      "label": "Manual trigger ID",
      "info": "Add a link anywhere in your theme with href=\"#your-id\" (matching this value) to open this popup on click.",
      "default": "open-subscribe-popup"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "popup_width",
      "label": "Popup width",
      "min": 400,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 60
    }
  ],
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Email popup"
    }
  ]
}
{% endschema %}
