<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section section--page-width spacing-style color-{{ section.settings.color_scheme }}" style="{% render 'spacing-padding', settings: section.settings %}">
  <div class="usp-section-heading">
    <div class="heading-right">
    <h3 class="h4" style="--color: var(--color-foreground-heading);">{{ section.settings.heading }}</h3>
      <a href="{{ section.settings.ig_link }}" class="ig-button">
