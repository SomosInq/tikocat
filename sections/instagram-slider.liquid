        </svg>
        <span>{{ section.settings.button_label }}</span>
      </a>
    </div>
    <div class="usp-slide-nav">
      <div class="ig-slide-prev usp-slide-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="7" height="13" viewBox="0 0 7 13" fill="none">
          <path d="M6.1875 0.6875L0.6875 6.1875L6.1875 11.6875" stroke="#10069F" stroke-width="1.375" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="ig-slide-next usp-slide-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="7" height="13" viewBox="0 0 7 13" fill="none">
          <path d="M0.6875 0.6875L6.1875 6.1875L0.6875 11.6875" stroke="#10069F" stroke-width="1.375" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </div>
  <instagram-slider class="swiper usp-slider">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="swiper-slide" {{ block.shopify_attributes }}>
          <div class="usp-slide-box">
            <div class="ig-image">
              <picture>
                {% if block.settings.mobile_image %}
                  <source 
                    media="(max-width: 767px)" 
                    srcset="{{ block.settings.mobile_image | image_url  }}"
                  >
                {% endif %}
                
                {% if block.settings.image %}
                  <img 
                    src="{{ block.settings.image | image_url }}" 
                    width="100%"
                    height="auto"
                  >
                {% endif %}
              </picture>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </instagram-slider>
  <div class="ig-slider-progress"></div>
</div>
<script
  src="{{ 'instagram-slider.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
<style>
#shopify-section-{{ section.id }}{
  overflow: hidden;
}
#shopify-section-{{ section.id }}  .usp-slider{
  display: block;
  width: 100%;
  overflow: visible;
}
#shopify-section-{{ section.id }}  .usp-section-heading{
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}
.usp-section-heading h2{
  margin-bottom: 0;
}
#shopify-section-{{ section.id }}  .usp-slide-nav {
  display: flex;
  gap: 8px;
}
#shopify-section-{{ section.id }}  .usp-slide-nav .usp-slide-button {
  width: 56px;
  height: 56px;
  aspect-ratio: 1 / 1;
  border: 1px solid #10069F;
  border-radius: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  user-select: none;
}
#shopify-section-{{ section.id }}  .usp-slide-nav .usp-slide-button.swiper-button-disabled{
  opacity: 0.3;
}
#shopify-section-{{ section.id }}  .usp-slide-box {
  position: relative;
  overflow: hidden;
}
#shopify-section-{{ section.id }}  .ig-image img{
  object-fit: cover;
  border-radius: 5px;
}
.ig-user-link{
  position: absolute;
  top: 16px;
  left: 16px;
  display: inline-flex;
  gap: 4px;
  align-items: center;
  padding: 4px 9.8px 6px 10px;
  border-radius: 28px;
  background: #FFF;
  color: #666;
  font-family: Inter;
  font-size: 11.703px;
  font-weight: 500;
}
#shopify-section-{{ section.id }} .heading-right {
    display: flex;
    align-items: center;
    gap: 31px;
}
#shopify-section-{{ section.id }} .heading-right h3{
  margin: 0;
}
#shopify-section-{{ section.id }} .ig-button{
  display: flex;
  padding: 12px 18px;
  justify-content: center;
  align-items: center;
  gap: 10px;
  border-radius: 85px;
  border: 1px solid var(--text-and-icons-sencodary-text-icon, rgba(26, 26, 26, 0.80));
  backdrop-filter: blur(1px);
}
#shopify-section-{{ section.id }} .ig-button span{
  color: #1A1A1ACC;
  font-size: 14px;
  font-style: normal;
  font-weight: 400;
  line-height: normal;
}

#shopify-section-{{ section.id }} .ig-slider-progress.swiper-pagination-progressbar {
    position: relative;
    margin-top: 48px;
}

#shopify-section-{{ section.id }} .ig-slider-progress.swiper-pagination-progressbar span.swiper-pagination-progressbar-fill {
    background: #1A1A1ACC;
}
</style>
{% schema %}
{
  "name": "Instagram Slider",
  "settings": [
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As Free As You Are"
    },
     {
      "type": "text",
      "id": "button_label",
      "label": "Label",
      "default": "Follow us on Instagram"
    },
    {
      "type": "url",
      "id": "ig_link",
      "label": "Instagram link"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "number",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "default": 72
    },
    {
      "type": "number",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "default": 72
    },
    {
      "type": "number",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Slider"
    }
  ]
}
{% endschema %}