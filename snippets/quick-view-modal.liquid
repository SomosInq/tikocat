<quick-view-dialog id="quick-view-dialog">
  <dialog
    class="quick-view-modal dialog-modal color-{{ settings.popover_color_scheme }}"
    ref="dialog"
    scroll-lock
  >
    <button
      ref="closeButton"
      on:click="/closeDialog"
      class="button button-unstyled close-button quick-view-modal__close"
      aria-label="{{ 'accessibility.close_dialog' | t }}"
    >
      {{- 'icon-close.svg' | inline_asset_content -}}
    </button>
    <div
      id="quick-view-modal-content"
      class="quick-view-modal__content"
    ></div>
  </dialog>
</quick-view-dialog>

{% stylesheet %}
  .quick-view-modal {
    padding: 0;
    border: var(--style-border-popover);
    height: fit-content;
    overflow: hidden;
    min-height: 500px;
    box-shadow: 0 5px 30px rgb(0 0 0 / var(--opacity-15));
    max-width: 1200px;
    width: 100%;

    @media screen and (max-width: 750px) {
      position: fixed;
      display: block;
      margin: auto 0 0 0;
      min-height: unset;
      max-width: 100%;
      border-radius: 0;
    }
  }

  .quick-view-modal[open] {
    @media screen and (min-width: 750px) {
      display: flex;
    }
  }

  .quick-view-modal .view-more-details__wrapper {
    @media screen and (max-width: 750px) {
      display: none;
    }
  }

  .quick-view-modal[open] {
    animation: modalSlideInTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .quick-view-modal.dialog-closing {
    animation: modalSlideOutTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .quick-view-modal__close {
    position: absolute;
    top: var(--margin-2xs);
    right: var(--margin-2xs);
    transition: transform 0.15s var(--animation-timing-bounce);
    z-index: var(--layer-raised);
  }

  .quick-view-modal__close:active {
    transform: scale(0.8);
  }

  .quick-view-modal__content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow-y: auto;
    max-height: 100vh;
    width: 100%;

    &:empty {
      min-height: 500px;
      place-items: center;
    }

    &:empty::before {
      content: '';
      width: 32px;
      height: 32px;
      border-radius: 50%;
      border: 3px solid rgb(var(--color-foreground-rgb) / var(--opacity-10));
      border-top-color: var(--color-foreground);
      animation: quickViewSpin 0.8s linear infinite;
    }

    @media screen and (max-width: 750px) {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto;
      padding-inline: var(--padding-xl);
      padding-block: var(--padding-xl);
      gap: var(--gap-lg);
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      height: auto; /* Prevent a bug in Safari where height:fit-content is not respected */
      max-height: 100vh;
    }
  }

  .quick-view-modal__content .media-gallery--grid .media-gallery__grid {
    grid-template-columns: 1fr;
  }

  .quick-view-modal__content .media-gallery--grid.media-gallery--two-column .product-media-container:first-child {
    grid-column: auto;
  }

  .quick-view-modal__content {
    /* One column */
    .media-gallery--grid:not(.media-gallery--two-column) .product-media > *,
    /* Two column, small first image */
    .media-gallery--grid.media-gallery--two-column:not(.media-gallery--large-first-image)
    .product-media-container:nth-of-type(odd)
    .product-media > *,
    /* Two column, large first image */
    .media-gallery--grid.media-gallery--two-column.media-gallery--large-first-image
      .product-media-container:is(:first-of-type, :nth-of-type(even))
      .product-media > *,
      /* Carousel */
    .media-gallery--carousel slideshow-container {
      border-top-left-radius: 0;
      border-bottom-left-radius: 0;
    }
  }

  .quick-view-modal__content .view-more-details__wrapper {
    display: flex;
    width: 100%;
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 0px 28px 8px;
  }

  .quick-view-modal .view-more-details__wrapper .view-more-details {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 20px 0;
    border-top:1px solid #F2F2FF;
  }

  .quick-view-modal__content .product-header {
    @media screen and (max-width: 750px) {
      display: flex;
      flex-direction: column;
      grid-column: 2 / -1;
      grid-row: 1;
      padding-right: var(--padding-2xl);
    }
  }

  .quick-view-modal__content .product-header a:not(product-price *) {
    @media screen and (max-width: 749px) {
      font-size: var(--font-size--md);
      font-weight: 500;
      color: inherit;
      width: fit-content;
    }
  }

  .quick-view-modal__content variant-picker,
  .quick-view-modal__content product-form-component {
    @media screen and (max-width: 750px) {
      grid-column: 1 / -1;
    }
  }

  .quick-view-modal__content .variant-picker__form {
    display: block;
  }

  .quick-view-modal__content .variant-option + .variant-option {
    margin-top: var(--padding-lg);
  }

  .quick-view-modal__content .product-media-container__zoom-button {
    cursor: default;
  }

  .quick-view-modal__content .product-details {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
    padding: 0 106px;
    dialog[open] & {
      animation: fadeSlideIn 0.3s var(--animation-timing-fade-in) both;
      animation-delay: 0.1s;
    }

    @media screen and (max-width: 750px) {
      grid-column: 2 / span 2;
      grid-row: span 1;
      overflow-y: auto;
      max-height: 100%;
      height: 100%;
    }
  }

  .quick-view-modal__content > * {
    min-height: 0;
  }

  .quick-view-modal__content .product-details :is(.view-product-title, .buy-buttons-block) {
    flex: 0 0 auto;
  }

  .quick-view-modal__content .product-details .variant-picker {
    --product-swatches-padding-block-end: 0px;

    flex: 1 1 auto;
    overflow-y: auto;
    min-height: 0;
    padding-block-end: calc(
      var(--product-swatches-padding-block-end) + var(--focus-outline-offset) + var(--focus-outline-width)
    );
  }

  .quick-view-modal__content .variant-option--swatches {
    padding-inline-start: var(--padding-2xs);
  }

  .quick-view-modal__content .variant-option--swatches legend {
    margin-inline-start: calc(-1 * var(--padding-2xs));
  }

  .quick-view-modal__content:not(:has(.product-information__media)) .product-details {
    grid-column: 1 / -1;
  }

  .quick-view-modal__content .view-product-title {
    display: flex;
    padding-block: 0;
    /* Prevent overlap between title and close button */
    padding-inline: 0 calc(var(--minimum-touch-target) / 2);
  }

  .quick-view-modal__content .view-product-title a {
    color: inherit;
    text-decoration: none;
    text-align: left;
    font-size: var(--font-size--2xl);
    font-weight: 600;
    line-height: 1.2;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s var(--animation-easing);
  }

  /*
   * Unlike Quick Add, Quick View is meant to give a full product overview, so
   * rating (.rating-wrapper) and description (.text-block.rte) stay visible
   * here instead of being hidden like they are in the Quick Add modal.
   */
  .quick-view-modal__content
    .product-details
    *:not(
      .group-block,
      .group-block-content,
      .buy-buttons-block,
      .buy-buttons-block *,
      .view-product-title,
      .view-product-title *,
      variant-picker,
      variant-picker *,
      product-price,
      product-price *,
      product-inventory,
      product-inventory *,
      .view-more-details__wrapper,
      .view-more-details__wrapper *,
      .rating-wrapper,
      .rating-wrapper *,
      .text-block.rte,
      .text-block.rte *
    ) {
    @media screen and (min-width: 750px) {
      /* stylelint-disable-next-line declaration-no-important */
      display: none !important;
    }
  }

  .quick-view-modal__content
    .group-block:not(
      :has(
          .buy-buttons-block,
          .buy-buttons-block *,
          .view-product-title,
          .view-product-title *,
          variant-picker,
          variant-picker *,
          product-price,
          product-price *,
          product-inventory,
          product-inventory *,
          .view-more-details__wrapper,
          .view-more-details__wrapper *,
          .rating-wrapper,
          .rating-wrapper *,
          .text-block.rte,
          .text-block.rte *
        ),
      .buy-buttons-block
    ) {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .quick-view-modal__content .group-block-content {
      gap: min(var(--gap-2xl), var(--gap));
    }

    .quick-view-modal__content .media-gallery__grid {
      gap: min(var(--gap-2xs), var(--image-gap));
      border-radius: var(--style-border-radius-popover, 0);
    }

    .quick-view-modal__content .media-gallery--grid .product-media img {
      border-radius: 0;
    }

    .quick-view-modal__content .media-gallery--grid .product-media-container:first-child {
      border-top-right-radius: var(--style-border-radius-popover, 0);
    }

    .quick-view-modal__content .media-gallery--grid .product-media-container:last-child {
      border-bottom-right-radius: var(--style-border-radius-popover, 0);
    }
  }

  .quick-view-modal__content .product-details > .group-block {
    padding: var(--padding-2xl);
    max-height: 100%;
  }

  .quick-view-modal__content slideshow-slide:not([aria-hidden='false']) {
    content-visibility: auto;
  }

  .quick-view-modal__content .product-information__media {
    width: 100%;
    position: relative;
    top: 0;
    animation: fadeIn 0.4s var(--animation-timing-fade-in) both;
  }

  .quick-view-modal media-gallery {
    padding: 0;
  }

  .quick-view-modal__content .product-information__media .product-highlights {
    display: none;
  }

  .quick-view-modal__content .product-information__media slideshow-arrows {
    display: none;
  }

  .quick-view-modal__content .product-information__media slideshow-container {
    display: block;
  }

  .quick-view-modal__content .sticky-content,
  .quick-view-modal__content .sticky-content--desktop {
    top: 0;
  }

  .quick-view-modal .product-media {
    width: 100%;
    height: 100%;
  }

  .quick-view-modal deferred-media {
    display: none;
  }
  .quick-view-modal__content slideshow-controls[pagination-position="right"] {
    display: none;
  }
  .quick-view-modal__content slideshow-controls[pagination-position="center"]{
    display: flex !important;
    align-items: center;
    justify-content: center;
  }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes quickViewSpin {
    to {
      transform: rotate(360deg);
    }
  }
{% endstylesheet %}
